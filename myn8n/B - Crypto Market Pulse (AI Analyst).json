      "id": "21acd34a-96b4-4f10-b493-387e6c69bb02",
      "name": "Aggregate - Actionable",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [
        368,
        384
      ]
    },
    {
      "parameters": {
        "jsCode": "const actionable = $json.data || [];\nconst brief = $('AI - Market Brief').first().json.output;\nconst snap = $('Code - Build Snapshot').first().json;\n\nlet report = `CRYPTO MARKET PULSE\\n${snap.generated_at}\\n\\n`;\nreport += `Overall mood: ${brief.overall_mood}\\n`;\nreport += `Risk to watch: ${brief.risk_to_watch}\\n\\n`;\nreport += `Trending: ${snap.trending}\\n\\n`;\nreport += `ACTIONABLE SIGNALS (${actionable.length}):\\n`;\nactionable.forEach(a => {\n  const s = a.signal_data;\n  report += `  - ${s.coin}: ${s.signal.toUpperCase()} — ${s.reason}\\n`;\n});\n\nreturn [{ json: {\n  report,\n  overall_mood: brief.overall_mood,\n  actionable_count: actionable.length,\n  full_brief: brief\n}}];"
      },
