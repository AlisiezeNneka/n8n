    {
      "parameters": {
        "jsCode": "// Trending arrives as a single object with coins[]\nconst coins = ($json.coins || []).map(c => c.item ? c.item.name : c.name);\nreturn [{ json: { trending: coins.slice(0, 7) } }];"
      },
      "id": "f7e4bad6-cc96-4cfe-9f98-39b9e7eb1730",
      "name": "Code - Extract Trending",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1104,
        480
      ]
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineByPosition",
        "options": {}
      },
      "id": "e7fddb65-b157-4a13-afe2-6bce03e9fc82",
      "name": "Merge - Data + Trending",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.1,
      "position": [
        -880,
        384
      ]
    },
    {
      "parameters": {
        "jsCode": "// Market data comes in as multiple items (one per coin) on input 0.\n// Trending comes from the Code node on input 1, but after merge-by-position\n// only the first item carries it, so pull it from the source node directly.\nconst trending = $('Code - Extract Trending').first().json.trending || [];\n\nconst coins = $input.all().map(i => i.json).filter(c => c.id);\n\nlet lines = coins.map(c => {\n  const p = c.current_price;\n  const h1 = (c.price_change_percentage_1h_in_currency ?? 0).toFixed(2);\n  const h24 = (c.price_change_percentage_24h_in_currency ?? c.price_change_percentage_24h ?? 0).toFixed(2);\n  const d7 = (c.price_change_percentage_7d_in_currency ?? 0).toFixed(2);\n  return `${c.name} (${c.symbol.toUpperCase()}): $${p} | 1h ${h1}% | 24h ${h24}% | 7d ${d7}% | mcap $${(c.market_cap/1e9).toFixed(1)}B`;\n});\n\nreturn [{ json: {\n  generated_at: new Date().toISOString(),\n  coin_count: coins.length,\n  snapshot: lines.join('\\n'),\n  trending: trending.join(', '),\n  raw_coins: coins.map(c => ({ name: c.name, symbol: c.symbol, h24: c.price_change_percentage_24h }))\n}}];"
      },
      "id": "fad2f738-e970-4147-bcd1-db6e62774d1d",
      "name": "Code - Build Snapshot",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -656,
        384
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Here is the current crypto market snapshot:\n\n{{ $json.snapshot }}\n\nTrending across the market right now: {{ $json.trending }}\n\nProduce a short market brief. For EACH coin give a signal (bullish / neutral / bearish) and a one-line reason grounded in its price moves. Then give an overall market mood and one risk to watch.",
        "hasOutputParser": true,
        "messages": {
          "messageValues": [
            {
              "message": "You are a measured crypto market analyst. You never give financial advice or price predictions. You describe momentum and sentiment based strictly on the percentage moves provided. Be concise and neutral in tone."
            }
          ]
        }
      },
      "id": "d4735de4-2d39-4463-9adc-1d17c8f3c719",
      "name": "AI - Market Brief",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
